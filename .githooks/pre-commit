#!/usr/bin/env bash
# Sync version across bindings when VERSION (or a derived file) is staged.
set -euo pipefail

root=$(git rev-parse --show-toplevel)
sync=$root/tools/sync_version.sh
[[ -x $sync ]] || exit 0

watch='^(VERSION|r/DESCRIPTION|python/pyproject\.toml|julia/Project\.toml)$'
git diff --cached --name-only | grep -qE "$watch" || exit 0

"$sync"
git add r/DESCRIPTION python/pyproject.toml julia/Project.toml